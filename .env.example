# Backend
# Local dev can use SQLite. Docker Compose overrides this with PostgreSQL.
DATABASE_URL=sqlite:///./stock_scheduler.db
ORCHESTRATOR_TYPE=codex
CODEX_BIN=/usr/bin/codex
GEMINI_BIN=gemini
CORS_ALLOW_ORIGINS=
NOTIFICATION_MODE=dry-run

# Telegram notification
# Set NOTIFICATION_MODE=telegram to send real Telegram push messages.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Korea Investment Securities Open API
# KIS_ENV can be virtual or real.
KIS_ENV=virtual
KIS_GRANT_TYPE=client_credentials

# Mock trading / virtual investment
KIS_VIRTUAL_APP_KEY=your_virtual_app_key_here
KIS_VIRTUAL_APP_SECRET=your_virtual_app_secret_here
KIS_VIRTUAL_BASE_URL=https://openapivts.koreainvestment.com:29443

# Real trading
KIS_REAL_APP_KEY=your_real_app_key_here
KIS_REAL_APP_SECRET=your_real_app_secret_here
KIS_REAL_BASE_URL=https://openapi.koreainvestment.com:9443
